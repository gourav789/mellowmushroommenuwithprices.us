  <!-- Contact Section -->
  <section class="section bg-white">
    <div class="container">
      <div class="contact-layout">
        
        <!-- Information Side -->
        <div class="contact-info reveal">
          <div class="pricing-note" style="margin-bottom:2rem; background:#fff5f5; border-left-color:var(--danger);">
            <strong style="color:var(--danger);">IMPORTANT NOTICE:</strong><br>
            This website is an independent informational website. We are NOT Mellow Mushroom. Do <strong>NOT</strong> use this form to place orders, request refunds from the restaurant, or submit complaints about your dining experience. For official restaurant issues, please contact your local Mellow Mushroom directly.
          </div>

          <div class="contact-info-card">
            <h3>📧 Email Us</h3>
            <p><strong>[email@example.com]</strong><br><small><em>(This email address can be updated later by the website owner.)</em></small></p>
          </div>

          <div class="contact-info-card">
            <h3>🔄 Frequently Requested Help</h3>
            <ul style="list-style-type:disc; margin-left:1.5rem; margin-top:0.5rem;">
              <li><strong>Report Incorrect Prices:</strong> Use the form to let us know if your local menu prices differ significantly from our estimates.</li>
              <li><strong>Report Broken Links:</strong> Help us keep the site functioning perfectly.</li>
              <li><strong>General Enquiry:</strong> Questions about our guides or how we collect data.</li>
              <li><strong>Business Enquiry:</strong> For partnership or advertising opportunities.</li>
              <li><strong>Feedback:</strong> Tell us how we can improve the site!</li>
            </ul>
          </div>
        </div>

        <!-- Form Side -->
        <div class="contact-form-wrap reveal delay-100">
          <form class="contact-form" action="#" method="POST" aria-label="Contact form">
            <h2 style="margin-bottom:1.5rem; color:var(--primary);">Send a Message</h2>
            
            <div class="form-group">
              <label for="name" class="form-label">Name</label>
              <input type="text" id="name" name="name" class="form-input" placeholder="Your name" required>
            </div>
            
            <div class="form-group">
              <label for="email" class="form-label">Email</label>
              <input type="email" id="email" name="email" class="form-input" placeholder="Your email address" required>
            </div>

            <div class="form-group">
              <label for="subject" class="form-label">Subject / Enquiry Type</label>
              <select id="subject" name="subject" class="form-input" required>
                <option value="">Select a reason...</option>
                <option value="General Enquiry">General Enquiry</option>
                <option value="Report Incorrect Prices">Report Incorrect Prices</option>
                <option value="Report Broken Link">Report Broken Links</option>
                <option value="Feedback">Website Feedback</option>
                <option value="Business Enquiry">Business Enquiry</option>
              </select>
            </div>
            
            <div class="form-group">
              <label for="message" class="form-label">Message</label>
              <textarea id="message" name="message" class="form-textarea" placeholder="How can we help you?" required></textarea>
            </div>
            
            <button type="submit" class="btn btn-primary btn-lg w-full">Send Message</button>
            <p style="font-size:0.85rem; color:var(--gray-500); margin-top:1rem; text-align:center;">By submitting this form, you acknowledge that we are an independent website.</p>
          </form>
        </div>

      </div>
    </div>
  </section>

